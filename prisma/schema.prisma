generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Game {
  id              Int       @id @default(autoincrement())
  title           String
  originalFile    String
  platform        String
  platformLabel   String
  source          String    @default("rom") // "rom" or "steam"
  coverUrl        String?
  screenshotUrls  String? // JSON array stored as string
  igdbId          Int?
  igdbScore       Float?
  metacriticScore Int?
  releaseDate     DateTime?
  genres          String? // JSON array stored as string
  developer       String?
  publisher       String?
  summary         String?
  videoIds        String?   // JSON array of YouTube video IDs
  artworkUrls     String?   // JSON array of artwork image URLs
  franchise       String?   // Franchise/series name (e.g., "Zelda")
  themes          String?   // JSON array of theme strings (e.g., "Horror", "Fantasy")
  aiFunFacts      String?
  aiStory         String?
  aiEnrichedAt    DateTime?
  isFavorite      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([originalFile, platform])
  @@index([platform])
  @@index([title])
}

model WishlistItem {
  id            Int      @id @default(autoincrement())
  title         String
  platform      String
  platformLabel String
  coverUrl      String?
  igdbScore     Float?
  summary       String?
  genres        String?  // JSON array
  screenshots   String?  // JSON array of URLs
  videoIds      String?  // JSON array of YouTube IDs
  developer     String?
  year          Int?
  createdAt     DateTime @default(now())

  @@unique([title, platform])
}

model Platform {
  id        String @id
  label     String
  icon      String @default("")
  color     String @default("#f59e0b")
  gameCount Int    @default(0)
  sortOrder Int    @default(0)
}

model Settings {
  id               Int    @id @default(1)
  deckHost         String @default("192.168.178.131")
  deckUser         String @default("deck")
  deckPassword     String @default("")
  igdbClientId     String @default("")
  igdbClientSecret String @default("")
  steamgriddbKey   String @default("")
  openrouterKey    String @default("")
  steamApiKey      String @default("")
  aiLanguage       String @default("en") // "en" or "de"
  romSearchUrl     String @default("https://romsfun.com/roms/{platformLabel}/?q={title}")
}

model Device {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   @default("custom")
  protocol  String   @default("ssh")
  host      String
  port      Int      @default(22)
  user      String
  password  String
  scanPaths String   @default("[]")
  blacklist String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
